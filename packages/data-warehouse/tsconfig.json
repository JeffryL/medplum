{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "types": ["node", "vitest/globals"],
    "lib": ["esnext"],
    "rootDir": "src",
    "outDir": "dist/types",
    "noEmit": false,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/postgres-testcontainer.ts"]
}
