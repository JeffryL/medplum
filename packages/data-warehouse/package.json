{
  "name": "@medplum/data-warehouse",
  "version": "5.1.9",
  "description": "Medplum Data Warehouse Export Tool",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medplum/medplum.git",
    "directory": "packages/data-warehouse"
  },
  "license": "Apache-2.0",
  "author": "Medplum <hello@medplum.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/types.d.ts",
  "bin": {
    "medplum-data-warehouse": "./dist/main.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "api-extractor": "api-extractor run --local",
    "build": "npm run clean && tsc && node esbuild.mjs && npm run api-extractor",
    "clean": "rimraf dist",
    "medplum-data-warehouse": "tsx src/main.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-athena": "3.1038.0",
    "@aws-sdk/client-s3": "3.1036.0",
    "@aws-sdk/client-s3tables": "3.1038.0",
    "@duckdb/node-api": "1.5.2-r.1",
    "commander": "12.1.0",
    "dotenv": "17.4.2",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "11.14.0",
    "testcontainers": "11.14.0"
  },
  "engines": {
    "node": ">=24.2.0"
  }
}
